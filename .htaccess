# Use this when your Hostinger document root is the Laravel root (public_html),
# not public_html/public. Place this file in public_html (project root).
# If you still get 404 on /admin/login, set document root to public_html/public instead.

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Serve Vite build assets from public/build/ so CSS/JS load when doc root is project root
    RewriteCond %{REQUEST_URI} ^/build/
    RewriteRule ^build/(.*)$ public/build/$1 [L]
    # Send all other requests to Laravel
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/index.php [L]
</IfModule>
